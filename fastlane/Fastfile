default_platform(:ios)

platform :ios do
  desc "Build and upload to TestFlight"
  lane :beta do
    build_app(
      workspace: "ios/BibleGuideAI.xcworkspace",
      scheme: "BibleGuideAI",
      export_method: "app-store"
    )
    upload_to_testflight(
      skip_waiting_for_build_processing: true
    )
  end

  desc "Upload to App Store"
  lane :release do
    build_app(
      workspace: "ios/BibleGuideAI.xcworkspace",
      scheme: "BibleGuideAI",
      export_method: "app-store"
    )
    upload_to_app_store(
      force: true,
      submit_for_review: false
    )
  end
end

platform :android do
  desc "Build and upload to Play Store internal"
  lane :beta do
    gradle(
      project_dir: "android",
      task: "bundleRelease"
    )
    upload_to_play_store(
      track: "internal",
      aab: "android/app/build/outputs/bundle/release/app-release.aab"
    )
  end

  desc "Upload to Play Store production"
  lane :release do
    gradle(
      project_dir: "android",
      task: "bundleRelease"
    )
    upload_to_play_store(
      track: "production",
      aab: "android/app/build/outputs/bundle/release/app-release.aab"
    )
  end
end
